{
  "version": "2.11",
  "name": "Цагаан Тана - Уламжлалт Анагаах Ухааны Эмнэлэг",
  "description": "Modern, sleek oriental medical hospital website with booking functionality",
  "children": [
    {
      "type": "frame",
      "id": "hero-section",
      "name": "Hero Section",
      "width": 1440,
      "height": 800,
      "fill": "#0F172A",
      "layout": "none",
      "children": [
        {
          "type": "image",
          "id": "hero-bg",
          "x": 0,
          "y": 0,
          "width": 1440,
          "height": 800,
          "src": "hero-acupuncture.jpg",
          "opacity": 0.4
        },
        {
          "type": "text",
          "id": "hero-title",
          "x": 100,
          "y": 250,
          "width": 600,
          "height": 80,
          "text": "Цагаан Тана",
          "fontSize": 72,
          "fontWeight": "bold",
          "fill": "#FFFFFF",
          "fontFamily": "Inter"
        },
        {
          "type": "text",
          "id": "hero-subtitle",
          "x": 100,
          "y": 340,
          "width": 500,
          "height": 40,
          "text": "Уламжлалт Анагаах Ухааны Эмнэлэг",
          "fontSize": 28,
          "fill": "#CBD5E1",
          "fontFamily": "Inter"
        },
        {
          "type": "text",
          "id": "hero-desc",
          "x": 100,
          "y": 400,
          "width": 500,
          "height": 60,
          "text": "Бариа засал · Зүү тавих · Массаж · Уламжлалт эмчилгээ",
          "fontSize": 18,
          "fill": "#94A3B8",
          "fontFamily": "Inter"
        },
        {
          "type": "button",
          "id": "hero-cta",
          "x": 100,
          "y": 480,
          "width": 200,
          "height": 56,
          "text": "Цаг авах",
          "fontSize": 16,
          "fontWeight": "600",
          "fill": "#10B981",
          "color": "#FFFFFF",
          "borderRadius": 8
        }
      ]
    },
    {
      "type": "frame",
      "id": "services-section",
      "name": "Services Section",
      "width": 1440,
      "height": 900,
      "fill": "#FFFFFF",
      "layout": "none",
      "children": [
        {
          "type": "text",
          "id": "services-title",
          "x": 100,
          "y": 80,
          "width": 400,
          "height": 50,
          "text": "Манай үйлчилгээ",
          "fontSize": 42,
          "fontWeight": "bold",
          "fill": "#0F172A",
          "fontFamily": "Inter"
        },
        {
          "type": "text",
          "id": "services-desc",
          "x": 100,
          "y": 140,
          "width": 600,
          "height": 30,
          "text": "Мэргэжлийн эмч нарын хяналтан доор хийгддэг эмчилгээ, үйлчилгээ",
          "fontSize": 18,
          "fill": "#64748B",
          "fontFamily": "Inter"
        },
        {
          "type": "card",
          "id": "service-1",
          "x": 100,
          "y": 220,
          "width": 380,
          "height": 500,
          "fill": "#FFFFFF",
          "borderColor": "#E2E8F0",
          "borderRadius": 16,
          "shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
          "children": [
            {
              "type": "image",
              "id": "service-img-1",
              "x": 0,
              "y": 0,
              "width": 380,
              "height": 250,
              "src": "acupuncture.jpg",
              "borderRadius": "16px 16px 0 0"
            },
            {
              "type": "text",
              "id": "service-title-1",
              "x": 24,
              "y": 280,
              "width": 332,
              "height": 32,
              "text": "Зүү тавих",
              "fontSize": 24,
              "fontWeight": "bold",
              "fill": "#0F172A"
            },
            {
              "type": "text",
              "id": "service-price-1",
              "x": 24,
              "y": 320,
              "width": 332,
              "height": 24,
              "text": "60,000₮ / цаг",
              "fontSize": 18,
              "fontWeight": "600",
              "fill": "#10B981"
            },
            {
              "type": "text",
              "id": "service-desc-1",
              "x": 24,
              "y": 360,
              "width": 332,
              "height": 80,
              "text": "Уламжлалт зүү тавих эмчилгээ. Өвдөлт намдаах, сэргээн засах үйлчилгээтэй.",
              "fontSize": 14,
              "fill": "#64748B"
            },
            {
              "type": "button",
              "id": "service-book-1",
