          "width": 380,
          "height": 500,
          "fill": "#FFFFFF",
          "borderColor": "#E2E8F0",
          "borderRadius": 16,
          "shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
          "children": [
            {
              "type": "image",
              "id": "service-img-3",
              "x": 0,
              "y": 0,
              "width": 380,
              "height": 250,
              "src": "baria.jpg",
              "borderRadius": "16px 16px 0 0"
            },
            {
              "type": "text",
              "id": "service-title-3",
              "x": 24,
              "y": 280,
              "width": 332,
              "height": 32,
              "text": "Бариа засал",
              "fontSize": 24,
              "fontWeight": "bold",
              "fill": "#0F172A"
            },
            {
              "type": "text",
              "id": "service-price-3",
              "x": 24,
              "y": 320,
              "width": 332,
              "height": 24,
              "text": "50,000₮ / цаг",
              "fontSize": 18,
              "fontWeight": "600",
              "fill": "#10B981"
            },
            {
              "type": "text",
              "id": "service-desc-3",
              "x": 24,
              "y": 360,
              "width": 332,
              "height": 80,
              "text": "Уламжлалт бариа засалын эмчилгээ. Мэдрэл, судасны өвчнүүдэд үр дүнтэй.",
              "fontSize": 14,
              "fill": "#64748B"
            },
            {
              "type": "button",
              "id": "service-book-3",
              "x": 24,
              "y": 440,
              "width": 332,
              "height": 48,
              "text": "Цаг авах",
              "fill": "#10B981",
              "color": "#FFFFFF",
              "borderRadius": 8
            }
          ]
        }
      ]
    },
    {
      "type": "frame",
      "id": "booking-section",
      "name": "Booking Section",
      "width": 1440,
      "height": 700,
      "fill": "#F8FAFC",
      "layout": "none",
      "children": [
        {
          "type": "text",
          "id": "booking-title",
          "x": 100,
          "y": 80,
          "width": 400,
          "height": 50,
          "text": "Цаг авах",
          "fontSize": 42,
          "fontWeight": "bold",
          "fill": "#0F172A"
        },
        {
          "type": "text",
          "id": "booking-desc",
          "x": 100,
          "y": 140,
          "width": 600,
          "height": 30,
          "text": "Доорх маягтыг бөглөж, таалагдсан үйлчилгээндээ цаг захиалаарай",
          "fontSize": 18,
          "fill": "#64748B"
        },
        {
          "type": "form",
          "id": "booking-form",
          "x": 100,
          "y": 200,
          "width": 600,
          "height": 450,
          "children": [
            {
              "type": "input",
              "id": "name-field",
              "x": 0,
              "y": 0,
              "width": 600,
              "height": 56,
              "placeholder": "Таны нэр",
              "borderRadius": 8,
              "borderColor": "#E2E8F0"
            },
            {
              "type": "input",
              "id": "phone-field",
              "x": 0,
              "y": 80,
              "width": 600,
              "height": 56,
              "placeholder": "Утасны дугаар",
              "borderRadius": 8,
              "borderColor": "#E2E8F0"
            },
            {
              "type": "select",
              "id": "service-select",
              "x": 0,
              "y": 160,
              "width": 600,
              "height": 56,
              "placeholder": "Үйлчилгээ сонгох",
              "options": ["Зүү тавих", "Массаж", "Бариа засал", "Уламжлалт эмчилгээ"],
              "borderRadius": 8,
              "borderColor": "#E2E8F0"
            },
            {
              "type": "input",
              "id": "date-field",
              "x": 0,
              "y": 240,
              "width": 600,
              "height": 56,
              "placeholder": "Огноо сонгох",
              "type": "date",
              "borderRadius": 8,
              "borderColor": "#E2E8F0"
            },
            {
              "type": "textarea",
              "id": "notes-field",
              "x": 0,
              "y": 320,
              "width": 600,
              "height": 80,
              "placeholder": "Нэмэлт мэдээлэл",
              "borderRadius": 8,
              "borderColor": "#E2E8F0"
            }
          ]
        },
        {
          "type": "button",
          "id": "submit-booking",
          "x": 100,
          "y": 650,
          "width": 600,
          "height": 56,
          "text": "Цаг захиалах",
          "fill": "#10B981",
          "color": "#FFFFFF",
          "borderRadius": 8,
          "fontSize": 16,
          "fontWeight": "600"
        }
      ]
    }
  ],
  "styles": {
    "colors": {
      "primary": "#10B981",
      "primaryDark": "#059669",
      "secondary": "#0F172A",
      "background": "#FFFFFF",
      "surface": "#F8FAFC",
      "text": "#0F172A",
      "textSecondary": "#64748B",
      "textMuted": "#94A3B8",
      "border": "#E2E8F0"
    },
    "typography": {
      "fontFamily": "Inter, system-ui, sans-serif",
      "headingWeight": "700",
      "bodyWeight": "400"
    },
    "spacing": {
      "section": "120px",
      "container": "1200px"
    }
  }
}
