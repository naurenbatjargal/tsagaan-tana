          "height": 500,
          "fill": "#FFFFFF",
          "borderColor": "#E2E8F0",
          "borderRadius": 16,
          "shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
          "children": [
            {
              "type": "image",
              "id": "service-img-2",
              "x": 0,
              "y": 0,
              "width": 380,
              "height": 250,
              "src": "massage.jpg",
              "borderRadius": "16px 16px 0 0"
            },
            {
              "type": "text",
              "id": "service-title-2",
              "x": 24,
              "y": 280,
              "width": 332,
              "height": 32,
              "text": "Массаж",
              "fontSize": 24,
              "fontWeight": "bold",
              "fill": "#0F172A"
            },
            {
              "type": "text",
              "id": "service-price-2",
              "x": 24,
              "y": 320,
              "width": 332,
              "height": 24,
              "text": "45,000₮ / цаг",
              "fontSize": 18,
              "fontWeight": "600",
              "fill": "#10B981"
            },
            {
              "type": "text",
              "id": "service-desc-2",
              "x": 24,
              "y": 360,
              "width": 332,
              "height": 80,
              "text": "Мэргэжлийн массажистын үйлчилгээ. Тайвшруулах, сэргээх массаж.",
